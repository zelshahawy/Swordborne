{
  "version": 2,
  "framework": null,
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "wasm",
  "headers": [
    {
      "source": "/(.*)\\.wasm",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/wasm"
        }
      ]
    }
  ]
}
